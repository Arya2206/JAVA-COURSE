//Write a Java program that creates a Student class with private fields for id, name, age, and gender. The Student class should have a constructor to initialize these fields and an overridden toString method to provide a string representation of the Student object.

package q11126;
public class Student {
	
	//write code here
	private String id;
	private String name;
	private int age;
	private char gender;

	public Student(String id, String name, int age, char gender){
		this.id = id;
		this.name = name;
		this.age = age;
		this.gender = gender;
	}
	public String toString(){
		return "Student [id = " +id + ", name = " +name+", age = "+age+", gender = "+gender+"]";
	}
}
